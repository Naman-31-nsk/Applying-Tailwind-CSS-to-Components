<!DOCTYPE html>
<html>
<head>
    <title>Responsive Profile Card</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="flex justify-center items-center h-screen bg-gray-100 p-4">

    <div class="bg-white shadow-lg rounded-2xl p-6 w-full max-w-md 
                md:max-w-2xl flex flex-col md:flex-row items-center md:items-start gap-6">
        
        <!-- Image -->
        <img src="https://i.pravatar.cc/150"
             class="w-24 h-24 md:w-32 md:h-32 rounded-full">

        <!-- Content -->
        <div class="text-center md:text-left">
            
            <h2 class="text-xl md:text-2xl font-bold">Lucky Kushwaha</h2>
            
            <p class="text-gray-500 mb-2">B.Tech CSE Student</p>
            
            <p class="text-sm md:text-base text-gray-600 mb-4">
                Passionate about coding, web development, and building real-world projects.
            </p>

            <!-- Buttons -->
            <div class="flex flex-col sm:flex-row gap-2 justify-center md:justify-start">
                <button class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600">
                    Follow
                </button>
                <button class="bg-gray-200 px-4 py-2 rounded-lg hover:bg-gray-300">
                    Message
                </button>
            </div>

        </div>

    </div>

</body>
</html>
